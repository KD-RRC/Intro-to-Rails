<div class="container mt-4">
  <h1>Breweries</h1>

  <%= form_with url: breweries_path, method: :get, class: "mb-3 d-flex gap-2" do %>
    <%= select_tag :country,
          options_for_select(@countries, params[:country]),
          include_blank: "All countries", class: "form-select", style: "max-width: 250px;",
          onchange: "this.form.requestSubmit()" %>
  <% end %>

  <table class="table table-striped">
    <thead>
      <tr><th>Name</th><th>Type</th><th>City</th><th>State/Province</th><th>Country</th></tr>
    </thead>
    <tbody>
      <% @breweries.each do |brewery| %>
        <tr>
          <td><%= link_to brewery.name, brewery %></td>
          <td><%= brewery.brewery_type %></td>
          <td><%= brewery.city %></td>
          <td><%= brewery.state_province %></td>
          <td><%= brewery.country %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
    <%= paginate @breweries %>
</div>